@inject IUiStatus Ui

@* Visas när UI gör väntande anrop. Håller fokus på att “något händer” utan att blockera sidstrukturen *@
@if (Ui.IsBusy)
{
  <div class="busy-overlay" role="status" aria-live="polite" aria-label="Laddar">
    <div class="spinner-border text-primary" style="width:2.5rem;height:2.5rem"></div>
  </div>
}
